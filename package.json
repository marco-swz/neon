{
  "name": "neon",
  "version": "1.0.0",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/neon/neon.esm.js",
  "exports": {
    ".": {
      "import": "./dist/neon/neon.esm.js",
      "require": "./dist/neon/neon.cjs.js"
    },
    "./ne-button": {
      "import": "./dist/components/ne-button.js",
      "types": "./dist/components/ne-button.d.ts"
    },
    "./ne-input": {
      "import": "./dist/components/ne-input.js",
      "types": "./dist/components/ne-input.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate",
    "storybook": "storybook dev -p 6006 --no-open"
  },
  "devDependencies": {
    "@stencil/core": "^4.43.2",
    "@stencil/storybook-plugin": "^0.5.9",
    "@storybook/addon-links": "^10.2.19",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "puppeteer": "^24.3.0",
    "storybook": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19"
  },
  "license": "MIT"
}
